# Fallback rules if the subdomain Document Root is set to the REPOSITORY ROOT
# instead of the recommended public/ folder.
#
# RECOMMENDED: point setup.rclegends.ca's Document Root at the public/ folder,
# in which case this file is never used. These rules are a safety net only.

Options -Indexes

# Block direct web access to application internals.
RedirectMatch 403 (?i)^/(app|vendor|config|storage|tools|tests)(/|$)

<FilesMatch "(?i)\.(php|md|json|lock|sample|dist|ini|log|sh)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# Allow the front-controller redirect (index.php) to run.
<FilesMatch "^index\.php$">
    <IfModule mod_authz_core.c>
        Require all granted
    </IfModule>
</FilesMatch>

# Route everything to public/ when this is the document root.
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^$ public/ [L]
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
