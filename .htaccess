# Safety net used ONLY when the subdomain's Document Root points at the
# REPOSITORY ROOT instead of the recommended public/ folder.
#
# IMPORTANT: every rule in this file must be URI-based (RedirectMatch /
# mod_rewrite). Directory-scoped rules like <FilesMatch> + Require cascade
# into every subfolder — including public/ — even when public/ IS the
# document root, because the server merges .htaccess files from parent
# directories downward. A FilesMatch that denied *.php here once blocked
# public/submit.php on the live host with a bare 403 on every submission.

Options -Indexes

# Application internals must never be web-addressable.
RedirectMatch 403 (?i)^/(app|vendor|config|storage|tools|tests)(/|$)
RedirectMatch 403 (?i)^/(readme\.md|composer\.(json|lock))$
RedirectMatch 403 ^/\.

# Serve the app from public/ when this folder is the document root.
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
